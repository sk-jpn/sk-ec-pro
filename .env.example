# ResendのAPIキー（サーバー側でのみ使用）
RESEND_API_KEY=re_xxxxxxxxx

# Resendで認証済みドメインの送信元アドレス
RESEND_FROM_EMAIL=contact@formosajapan.com

# trueの場合はメール送信せず、フォームの画面遷移のみ確認
ESTIMATE_TEST_MODE=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxx

# 公開URL（metadata/canonical用）
NEXT_PUBLIC_SITE_URL=https://formosajapan.com/ec

# 管理画面へのログインを許可するGoogleアカウント（複数はカンマ区切り）
ADMIN_EMAILS=admin@formosajapan.com

# Stripe Checkout
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
SITE_URL=https://formosajapan.com

# Cloudflare Turnstile（localhostではCloudflare公式テストキーへ差し替え）
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
